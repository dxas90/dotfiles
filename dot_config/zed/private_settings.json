// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "context_servers": {
    "mcp-server-playwright": {
      "enabled": false,
      "remote": false,
      "settings": {
        "browser": "chromium",
        "headless": false,
      },
    },
    "context7": {
      "enabled": true,
      "url": "https://mcp.context7.com/mcp",
    },
    "aws-knowledge-mcp-server": {
      "enabled": true,
      "url": "https://knowledge-mcp.global.api.aws",
    },
    "sequential-thinking": {
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "command": "npx",
    },
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "tool_permissions": {
      "tools": {
        "create_directory": {
          "default": "allow",
        },
      },
    },
    "default_model": {
      "provider": "ollama",
      "model": "granite4.1:8b-q4_K_M",
      "enable_thinking": false,
    },
    "dock": "right",
    "favorite_models": [
      {
        "provider": "ollama",
        "model": "qwen3.5:latest",
        "enable_thinking": true,
      },
    ],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "project_panel": {
    "dock": "left",
  },
  "edit_predictions": {
    "provider": "ollama",
    "ollama": {
      "api_url": "http://localhost:11434",
      "model": "qwen2.5-coder:7b-instruct-q4_K_M",
      "prompt_format": "infer",
      "max_output_tokens": 64,
    },
  },
  "terminal": {
    "shell": {
      "program": "bash",
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "git": {
    "inline_blame": {
      "enabled": true,
    },
  },
  "base_keymap": "VSCode",
  "ensure_final_newline_on_save": true,
  "agent_servers": {
    "deepagents": {
      "type": "custom",
      "command": "uvx",
      "args": [
        "--refresh",
        "--from",
        "git+https://github.com/dxas90/opsy-acp",
        "opsy-acp",
      ],
    },
    "gemini": {
      "type": "registry",
    },
    "github-copilot-cli": {
      "type": "registry",
    },
    "cline": {
      "type": "registry",
    },
    "claude-acp": {
      "default_config_options": {
        "effort": "max",
        "model": "sonnet[1m]",
      },
      "favorite_config_option_values": {
        "effort": ["max"],
      },
      "type": "registry",
    },
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Catppuccin Mocha",
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
}
